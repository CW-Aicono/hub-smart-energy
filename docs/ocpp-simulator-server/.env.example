# ============================================
# AICONO EMS - OCPP Simulator (Hetzner)
# ============================================

# Bearer-Token zum Schutz der HTTP-API.
# WICHTIG: Muss exakt mit dem Lovable-Secret OCPP_SIMULATOR_API_KEY uebereinstimmen.
SIMULATOR_API_KEY=changeme-please-paste-the-real-key-here

# HTTP-Port, auf dem die Simulator-API lauscht (intern, nur 127.0.0.1)
PORT=8090

# Maximale Anzahl gleichzeitig laufender Simulator-Instanzen pro Tenant.
# Sicherheitsnetz auf Container-Ebene; das harte Limit erzwingt zusaetzlich die Edge Function.
MAX_INSTANCES_PER_TENANT=3

# Maximale Gesamtanzahl Simulator-Instanzen (alle Tenants zusammen).
MAX_TOTAL_INSTANCES=50
