# Lovable-Cloud-Verbindung — diese Adresse bleibt unverändert
SUPABASE_URL=https://xnveugycurplszevdxtw.supabase.co

# OCPP-Server-Schlüssel — MUSS exakt derselbe Wert sein wie im Lovable Secret OCPP_SERVER_API_KEY.
# Wenn dieser Wert falsch ist, verbindet der Browser kurz und bricht sofort mit code=1006 ab.
OCPP_SERVER_API_KEY=hier-den-exakten-ocpp-server-schluessel-eintragen

# Domain für die OCPP-Endpunkte (siehe Caddyfile). Trage hier deine Subdomain ein.
OCPP_DOMAIN=ocpp.deine-domain.de

# HTTP-Port, auf dem der Node-Server intern lauscht (Caddy reicht von 443 nach 8080 weiter).
PORT=8080

# Logging-Level: debug | info | warn | error
LOG_LEVEL=info

# Keep-Alive: alle wieviel Sekunden ein WebSocket-Ping zur Wallbox geht
PING_INTERVAL_SECONDS=25

# Idle-Timeout: nach wieviel Sekunden ohne Frame die Verbindung als tot gilt
IDLE_TIMEOUT_SECONDS=120

# Wie häufig pending_ocpp_commands gepollt wird (ms). 0 = nur Realtime, kein Polling
COMMAND_POLL_INTERVAL_MS=2000

# Realtime aktivieren (true/false) — Postgres LISTEN/NOTIFY auf pending_ocpp_commands
ENABLE_REALTIME=true

# Startprüfung: Der Server startet nur, wenn diese Test-Wallbox in Lovable Cloud gefunden wird.
# So erkennen wir falsche Schlüssel oder falsche Backend-Adressen sofort beim Neustart.
OCPP_STARTUP_CHECK_ID=testbox01
