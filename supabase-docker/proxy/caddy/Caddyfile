# Frontend (React-App) – Haupt-Domain (ems.aicono.org)
{$APP_DOMAIN} {
    reverse_proxy frontend:80
    header -server
    header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://{$API_DOMAIN} https://*.tile.openstreetmap.org; font-src 'self'; connect-src 'self' https://{$API_DOMAIN} wss://{$API_DOMAIN} https://api.open-meteo.com https://*.tile.openstreetmap.org https://api.energy-charts.info https://nominatim.openstreetmap.org; frame-ancestors 'self' https://*.lovable.app https://*.lovable.dev https://*.lovableproject.com; frame-src 'self' https://{$API_DOMAIN} blob:; object-src 'none'; base-uri 'self';"
}

